// Deno workspace configuration for raze-tui contract and property tests.
{
  "name": "raze-tui",
  "version": "0.2.0",
  "tasks": {
    "test": "deno test tests/ --allow-none",
    "test:unit": "deno test tests/unit/",
    "test:property": "deno test tests/property/",
    "test:e2e": "deno test tests/e2e/",
    "test:aspect": "deno test tests/aspect/",
